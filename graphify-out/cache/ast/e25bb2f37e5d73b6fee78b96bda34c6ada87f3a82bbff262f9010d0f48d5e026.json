.content),\n          rewritten.content,\n          rewritten.summary,\n          oldRow.source_json,\n          oldRow.confidence,\n          oldRow.tags_json,\n          oldRow.domain,\n          ((oldRow.version as number) || 1) + 1,\n          entry.id, // supersedes the old entry\n          oldRow.similar_sentences ?? '[]',\n          oldRow.nature,\n          oldRow.function_tag,\n          oldRow.knowledge_domain,\n          now,\n          now,\n        );\n      })", "is_member_call": false, "source_file": "/root/.openclaw/workspace/projects/kivo/src/cli/cmd-upgrade-quality.ts", "source_location": "L134"}, {"caller_nid": "cli_cmd_upgrade_quality_runupgradequality", "callee": "transaction", "is_member_call": true, "source_file": "/root/.openclaw/workspace/projects/kivo/src/cli/cmd-upgrade-quality.ts", "source_location": "L134"}, {"caller_nid": "cli_cmd_upgrade_quality_runupgradequality", "callee": "log", "is_member_call": true, "source_file": "/root/.openclaw/workspace/projects/kivo/src/cli/cmd-upgrade-quality.ts", "source_location": "L168"}, {"caller_nid": "cli_cmd_upgrade_quality_runupgradequality", "callee": "slice", "is_member_call": true, "source_file": "/root/.openclaw/workspace/projects/kivo/src/cli/cmd-upgrade-quality.ts", "source_location": "L168"}, {"caller_nid": "cli_cmd_upgrade_quality_runupgradequality", "callee": "slice", "is_member_call": true, "source_file": "/root/.openclaw/workspace/projects/kivo/src/cli/cmd-upgrade-quality.ts", "source_location": "L168"}, {"caller_nid": "cli_cmd_upgrade_quality_runupgradequality", "callee": "push", "is_member_call": true, "source_file": "/root/.openclaw/workspace/projects/kivo/src/cli/cmd-upgrade-quality.ts", "source_location": "L172"}, {"caller_nid": "cli_cmd_upgrade_quality_runupgradequality", "callee": "error", "is_member_call": true, "source_file": "/root/.openclaw/workspace/projects/kivo/src/cli/cmd-upgrade-quality.ts", "source_location": "L173"}, {"caller_nid": "cli_cmd_upgrade_quality_runupgradequal