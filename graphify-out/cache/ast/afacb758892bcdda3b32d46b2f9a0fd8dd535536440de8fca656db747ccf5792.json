n": "L171"}, {"caller_nid": "lib_semantic_search_embedquery", "callee": "set", "is_member_call": true, "source_file": "/root/.openclaw/workspace/projects/kivo/web/lib/semantic-search.ts", "source_location": "L204"}, {"caller_nid": "lib_semantic_search_embedquery", "callee": "delete", "is_member_call": true, "source_file": "/root/.openclaw/workspace/projects/kivo/web/lib/semantic-search.ts", "source_location": "L208"}]}